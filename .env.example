# ── Vision API ────────────────────────────────────────────────
VISION_PROVIDER=anthropic          # "anthropic" or "openai"
ANTHROPIC_API_KEY=sk-ant-XXXX
OPENAI_API_KEY=sk-XXXX

# ── Wake Word ──────────────────────────────────────────────────
WAKE_WORD_MODEL_PATH=./models/wake_word/hey_wiz.onnx
WAKE_WORD_THRESHOLD=0.5
WAKE_SAMPLE_RATE=16000
WAKE_WORD_ALLOW_BUNDLED_FALLBACK=true
WAKE_WORD_BUNDLED_MODEL_NAME=hey_jarvis

# ── OpenClaw ──────────────────────────────────────────────────
OPENCLAW_GW_URL=ws://127.0.0.1:18789
OPENCLAW_GW_ORIGIN=http://192.168.50.18:18789
OPENCLAW_TOKEN=your-openclaw-gateway-token
OPENCLAW_SESSION_ID=wiz-voice
OPENCLAW_TIMEOUT=60

# ── Paths (override only if non-default) ─────────────────────
# WHISPER_MODEL_PATH=./models/ggml-small.en-q8_0.bin
# PIPER_MODEL_PATH=./models/en_US-lessac-high.onnx

# ── Audio tuning ──────────────────────────────────────────────
# MIC_NAME=USB PnP Sound Device
# SPEAKER_NAME=UACDemoV1.0
# SAMPLE_RATE=48000
# SILENCE_THRESHOLD=0.01
# SILENCE_DURATION=1.5
# MAX_RECORD_SECONDS=30

# ── Touchscreen UI (5-inch display) ───────────────────────────
# ENABLE_UI=true
# DISPLAY_WIDTH=800
# DISPLAY_HEIGHT=480
# UI_FPS=30
# UI_BACKEND=wayland
# UI_FBCON_FALLBACK=true
# UI_ASSETS_PATH=./assets/face
