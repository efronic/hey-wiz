# ── Vision API ────────────────────────────────────────────────
VISION_PROVIDER=anthropic          # "anthropic" or "openai"
ANTHROPIC_API_KEY=sk-ant-XXXX
OPENAI_API_KEY=sk-XXXX

# ── OpenClaw ──────────────────────────────────────────────────
OPENCLAW_GW_URL=ws://127.0.0.1:18789
OPENCLAW_GW_ORIGIN=http://192.168.50.18:18789
OPENCLAW_TOKEN=your-openclaw-gateway-token
OPENCLAW_SESSION_ID=wiz-voice
OPENCLAW_TIMEOUT=60

# ── Paths (override only if non-default) ─────────────────────
# WHISPER_MODEL_PATH=./models/ggml-base.en.bin
# PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx
# PIPER_BINARY=piper

# ── Audio tuning ──────────────────────────────────────────────
# WAKE_WORD_MODEL=hey_jarvis
# WAKE_WORD_THRESHOLD=0.5
# SILENCE_THRESHOLD=500
# SILENCE_DURATION=1.5
# MAX_RECORD_SECONDS=30
